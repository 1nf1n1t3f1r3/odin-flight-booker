<h1>Flights#index</h1>
<p>Find me in app/views/flights/index.html.erb</p>

<h1>Search Flights</h1>

<%= form_with url: flights_path, method: :get, local: true do |f| %>
  <div>
    <%= f.label :departure_airport_id, "Departure Airport" %>
    <%= f.select :departure_airport_id, options_from_collection_for_select(@airports, :id, :code, params[:departure_airport_id]), include_blank: "Any" %>
  </div>

  <div>
    <%= f.label :arrival_airport_id, "Arrival Airport" %>
    <%= f.select :arrival_airport_id, options_from_collection_for_select(@airports, :id, :code, params[:arrival_airport_id]), include_blank: "Any" %>
  </div>

 <%# Only Dates where there's a Flight %>
  <div>
  <%= label_tag :date, "Date" %>
  <%= select_tag :date,
      options_for_select(
        @available_dates.map { |d| [d.strftime("%d %b %Y"), d] },
        params[:date]
      ),
      include_blank: "Any date" %>
  </div>

  <div>
  <%= label_tag :passengers, "Passengers" %>
  <%= select_tag :passengers,
      options_for_select((1..4).to_a, params[:passengers]),
      include_blank: "Select passengers" %>
</div>

  <div>
    <%= f.submit "Search" %>
  </div>
<% end %>

<h2>Results</h2>
<% if @flights.any? %>
  <ul>
    <% @flights.each do |flight| %>
      <li>
        <%= flight.departure_airport.code %> → <%= flight.arrival_airport.code %> 
        at <%= flight.departure_time.strftime("%b %d, %Y %H:%M") %>, duration: <%= flight.duration %> mins
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No flights found</p>
<% end %>